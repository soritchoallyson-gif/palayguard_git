# ========== DATABASE ==========
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=palayguard
DB_PORT=3306

# ========== SERVER ==========
PORT=3001
NODE_ENV=development

# ========== AUTHENTICATION ==========
JWT_SECRET=your_long_jwt_secret_for_user_authentication

# ========== ARDUINO / IOT SENSOR ==========
# IMPORTANT: Use a SIMPLE API key for Arduino, NOT the JWT_SECRET
# The JWT_SECRET is complex and unreliable for embedded systems
ARDUINO_API_KEY=simple_api_key_123

# ========== ALERTS ==========
MOISTURE_THRESHOLD=40
CRITICAL_MOISTURE_LEVEL=20

# ========== PUSH NOTIFICATIONS ==========
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ========== ENVIRONMENT ==========
# Set to 'production' for Railway/Heroku deployment
ENVIRONMENT=development
